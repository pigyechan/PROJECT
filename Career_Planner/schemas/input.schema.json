{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["brief_hash", "created_at", "job_postings", "user_background"],
  "properties": {
    "brief_hash": { "type": "string" },
    "created_at": { "type": "string" },
    "job_postings": {
      "type": "array",
      "minItems": 5,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id":   { "type": "integer" },
          "text": { "type": "string" }
        }
      }
    },
    "user_background": {
      "type": "object",
      "required": ["experience", "target_domain", "career_goal"],
      "properties": {
        "experience":    { "type": "string" },
        "target_domain": { "type": "string" },
        "career_goal":   { "type": "string" }
      }
    }
  }
}
