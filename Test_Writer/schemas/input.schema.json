{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["brief_hash", "brief", "created_at"],
  "properties": {
    "brief_hash": { "type": "string" },
    "brief": {
      "type": "object",
      "required": ["feature_name", "requirements"],
      "properties": {
        "feature_name": { "type": "string", "minLength": 1 },
        "requirements": { "type": "string", "minLength": 1 },
        "context": { "type": "string" }
      }
    },
    "created_at": { "type": "string" }
  }
}
