{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Pipeline Verdict (Evaluator + Validator)",
	"type": "object",
	"required": ["brief_hash", "verdict", "rubric_scores"],
	"properties": {
		"brief_hash": {"type": "string", "pattern": "^[a-f0-9]{8,}$"},
		"verdict": {"enum": ["PASS", "REJECT"]},
		"rubric_scores": {
			"type": "object",
			"required": ["scores", "weights", "weighted_total"],
			"properties": {
				"scores": {
					"type": "object",
					"patternProperties": {"^[a-z_]+$": {"type": "number", "minimum": 0, "maximum": 5}}
				},
				"weights": {
				"type": "object",
				"patternProperties": {"^[a-z_]+$": {"type": "number", "minimum": 0, "maximum": 1}}
				},
				"weighted_total": {"type": "number", "minimum": 0, "maximum": 5}
			}
		},
		"contract_errors": {
			"type": "array",
			"items": {"type": "string"}
		},
		"evaluator_model": {"type": "string"},
		"evaluated_at": {"type": "string", "format": "date-time"}
	},
	"additionalProperties": false
}