{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["brief_hash", "brief", "created_at"],
  "properties": {
    "brief_hash": { "type": "string" },
    "brief": {
      "type": "object",
      "required": ["feature_name", "code"],
      "properties": {
        "feature_name": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "context": { "type": "string" },
        "test_project_dir": {
          "type": "string",
          "description": "Validate 단계에서 gradle test 를 실행할 프로젝트 경로 (선택). 없으면 GREEN 확인은 건너뛴다."
        }
      }
    },
    "created_at": { "type": "string" }
  }
}
